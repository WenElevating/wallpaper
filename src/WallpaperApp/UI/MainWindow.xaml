<Window x:Class="WallpaperApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WallpaperApp.UI.ViewModels"
        xmlns:loc="clr-namespace:WallpaperApp.Localization"
        Title="WallpaperApp" Width="900" Height="600"
        Background="#1E1E2E" Foreground="#CDD6F4"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: language selector (right-aligned) -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc LanguageLabel}" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#CDD6F4"/>
                <ComboBox x:Name="LanguageComboBox" Width="130"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="中文" Tag="zh-CN"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Wallpaper List -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock DockPanel.Dock="Top" Text="{loc:Loc LibraryLabel}" FontSize="18" FontWeight="SemiBold"
                           Foreground="#CDD6F4" Margin="0,0,0,12"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="{loc:Loc ImportFilesButton}" Click="ImportButton_Click"
                            Background="#3B3B5C" Foreground="#CDD6F4" BorderThickness="0"
                            Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="{loc:Loc PauseAllText}" Click="PauseAllButton_Click"
                            Background="#3B3B5C" Foreground="#CDD6F4" BorderThickness="0"
                            Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="{loc:Loc ResumeAllText}" Click="ResumeAllButton_Click"
                            Background="#3B3B5C" Foreground="#CDD6F4" BorderThickness="0"
                            Padding="12,6"/>
                </StackPanel>

                <ListBox x:Name="WallpaperListBox"
                         ItemsSource="{Binding Wallpapers}"
                         Background="#2A2A3C" Foreground="#CDD6F4"
                         BorderThickness="0" Padding="4"
                         SelectionChanged="WallpaperListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,6">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SourceType}" FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Width="1" Fill="#3B3B5C" Margin="0,32,0,0"/>

            <!-- Right Panel: Monitor List -->
            <DockPanel Grid.Column="2" Margin="16,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="{loc:Loc MonitorsLabel}" FontSize="18" FontWeight="SemiBold"
                           Foreground="#CDD6F4" Margin="0,0,0,12"/>

                <ListBox x:Name="MonitorListBox"
                         ItemsSource="{Binding Monitors}"
                         Background="#2A2A3C" Foreground="#CDD6F4"
                         BorderThickness="0" Padding="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,6">
                                <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                                <TextBlock FontSize="11" Opacity="0.6">
                                    <Run Text="{Binding Width}"/>
                                    <Run Text=" x "/>
                                    <Run Text="{Binding Height}"/>
                                </TextBlock>
                                <Button Content="{loc:Loc SetWallpaperButton}" Click="SetWallpaperButton_Click"
                                        Tag="{Binding}"
                                        Background="#3B3B5C" Foreground="#CDD6F4" BorderThickness="0"
                                        Padding="12,4" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
