<Window x:Class="WallpaperApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WallpaperApp.UI.ViewModels"
        xmlns:views="clr-namespace:WallpaperApp.UI.Views"
        xmlns:loc="clr-namespace:WallpaperApp.Localization"
        Title="WallpaperApp" Width="1040" Height="700" MinWidth="840" MinHeight="540"
        Background="Transparent"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Search box: rounded, magnifier icon + placeholder. -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <Grid>
                                <Path Data="M10,10 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 M14,14 L18,18"
                                      Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.6"
                                      HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="30,0,8,0"
                                              VerticalAlignment="Center" Focusable="False"/>
                                <TextBlock x:Name="Placeholder" Text="{loc:Loc SearchPlaceholder}"
                                           Margin="30,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}" IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base left-rail nav item: transparent; per-button styles add the active look. -->
        <Style x:Key="NavItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Border x:Name="Root" CornerRadius="8" ClipToBounds="True">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Left navigation rail ===== -->
        <Border Grid.Column="0" Width="82"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Import (accent, labeled) -->
                <Button Grid.Row="0" Margin="10,18,10,8" Height="60" Command="{Binding ImportCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#89B4FA" Offset="0"/>
                                        <GradientStop Color="#B4BEFE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#89B4FA" Opacity="0.3" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#89B4FA" Opacity="0.7" BlurRadius="22" ShadowDepth="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M26,12 L38,12 M32,6 L32,18" Stroke="#0B0B14" StrokeThickness="2.4"
                              Width="22" Height="22" Stretch="Uniform"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc ImportLabel}" FontSize="11" Foreground="#0B0B14"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Library nav -->
                <Button Grid.Row="1" Height="58" Margin="6,2" Command="{Binding GoBackCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavItemButton}">
                            <Setter Property="ToolTip" Value="{loc:Loc LibraryLabel}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSettings}" Value="False">
                                    <Setter Property="Background" Value="#22374C63"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M4,4 H10.5 V10.5 H4 Z M13.5,4 H20 V10.5 H13.5 Z M4,13.5 H10.5 V20 H4 Z M13.5,13.5 H20 V20 H13.5 Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="22" Height="22" Stretch="Uniform"
                              HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{loc:Loc LibraryLabel}" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Settings nav (pinned to the bottom of the rail) -->
                <Button Grid.Row="3" Height="58" Margin="6,2" Command="{Binding GoSettingsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavItemButton}">
                            <Setter Property="ToolTip" Value="{loc:Loc SettingsLabel}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSettings}" Value="True">
                                    <Setter Property="Background" Value="#22374C63"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M19.43,12.98 C19.47,12.66 19.5,12.34 19.5,12 C19.5,11.66 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.87,5.07 L14.49,2.42 A0.5,0.5 0 0,0 14,2 L10,2 A0.5,0.5 0 0,0 9.51,2.42 L9.13,5.07 C8.52,5.32 7.96,5.66 7.44,6.05 L4.95,5.05 C4.72,4.96 4.46,5.05 4.34,5.27 L2.34,8.73 C2.21,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.67 4.5,12 C4.5,12.33 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.22,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.13,18.93 L9.51,21.58 A0.5,0.5 0 0,0 10,22 L14,22 A0.5,0.5 0 0,0 14.49,21.58 L14.87,18.93 C15.48,18.68 16.04,18.34 16.56,17.95 L19.05,18.95 C19.28,19.04 19.54,18.95 19.66,18.73 L21.66,15.27 C21.79,15.05 21.73,14.78 21.54,14.63 Z M12,15.5 A3.5,3.5 0 1,1 12,8.5 A3.5,3.5 0 1,1 12,15.5 Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="22" Height="22" Stretch="Uniform"
                              HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <TextBlock Text="{loc:Loc SettingsLabel}" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== Content ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,12"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding HeaderTitle}" FontSize="19" FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLibrary}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBox Style="{StaticResource SearchTextBox}" Width="240" Margin="0,0,10,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox x:Name="SortComboBox" Width="116" Margin="0,0,10,0"
                                      SelectedIndex="0" SelectionChanged="SortComboBox_SelectionChanged">
                                <ComboBoxItem Content="{loc:Loc SortRecent}" Tag="Recent"/>
                                <ComboBoxItem Content="{loc:Loc SortName}" Tag="Name"/>
                                <ComboBoxItem Content="{loc:Loc SortSize}" Tag="Size"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Pause/Resume toggle (library + detail only; disabled when no wallpaper is set) -->
                        <Button Command="{Binding PauseToggleCommand}" IsEnabled="{Binding HasActivePlayback}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Setter Property="ToolTip" Value="{loc:Loc PauseAllText}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="ToolTip" Value="{loc:Loc ResumeAllText}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSettings}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid Width="20" Height="20">
                                <Path Data="M6,4 V16 M14,4 V16" Stroke="{StaticResource TextBrush}" StrokeThickness="2.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M7,4 L17,10 L7,16 Z" Fill="{StaticResource TextBrush}">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: library / detail / settings -->
            <Grid Grid.Row="1">
                <views:LibraryView>
                    <views:LibraryView.Style>
                        <Style TargetType="views:LibraryView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentView}" Value="Library">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:LibraryView.Style>
                </views:LibraryView>

                <views:WallpaperDetailView>
                    <views:WallpaperDetailView.Style>
                        <Style TargetType="views:WallpaperDetailView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentView}" Value="Detail">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:WallpaperDetailView.Style>
                </views:WallpaperDetailView>

                <views:SettingsView>
                    <views:SettingsView.Style>
                        <Style TargetType="views:SettingsView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentView}" Value="Settings">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:SettingsView.Style>
                </views:SettingsView>
            </Grid>
        </Grid>
        <!-- In-app toast (success / error), replaces the system MessageBox -->
        <Border Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,32"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVis}}"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="12"/>
                    <Setter Property="Padding" Value="18,12"/>
                    <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastError}" Value="True">
                            <Setter Property="BorderBrush" Value="#F38BA8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <Path Data="M5,12 L10,17 L19,7" Stroke="#A6E3A1" StrokeThickness="2.6"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsToastError}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Path Data="M12,7 V13 M12,16.5 V17.2" Stroke="#F38BA8" StrokeThickness="2.6"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsToastError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <TextBlock Text="{Binding ToastMessage}" VerticalAlignment="Center" FontSize="14"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>
        </Grid>
    </Border>
</Window>
