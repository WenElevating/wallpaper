<UserControl x:Class="WallpaperApp.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:WallpaperApp.Localization"
             Foreground="{StaticResource TextBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24" MaxWidth="560">
            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc LanguageLabel}" VerticalAlignment="Center" FontSize="14"/>
                    <ComboBox Grid.Column="1" x:Name="LanguageComboBox" Width="150"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="中文" Tag="zh-CN"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc PauseOnFullscreenLabel}" VerticalAlignment="Center" FontSize="14"/>
                    <CheckBox Grid.Column="1" x:Name="PauseOnFullscreenCheckBox" VerticalAlignment="Center"
                              IsChecked="{Binding IsGlobalPauseOnFullscreen, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc PauseOnBatteryLabel}" VerticalAlignment="Center" FontSize="14"/>
                    <CheckBox Grid.Column="1" x:Name="PauseOnBatteryCheckBox" VerticalAlignment="Center"
                              IsChecked="{Binding IsPauseOnBattery, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc PauseOnRemoteSessionLabel}" VerticalAlignment="Center" FontSize="14"/>
                    <CheckBox Grid.Column="1" x:Name="PauseOnRemoteSessionCheckBox" VerticalAlignment="Center"
                              IsChecked="{Binding IsPauseOnRemoteSession, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc HotkeyTogglePauseLabel}" FontSize="14"/>
                        <TextBlock Text="{Binding Settings.Hotkeys.TogglePause.DisplayString}"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="ResetHotkeyButton" Content="{loc:Loc HotkeyResetButton}"
                            Padding="12,4" Click="ResetHotkeyButton_Click"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,13" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc SettingsStorageLocation}" FontSize="14"/>
                        <TextBlock Text="{Binding LibraryRootDisplay}"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{loc:Loc SettingsStorageHint}"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                                   Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap" MaxWidth="380"/>
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Content="{loc:Loc SettingsStorageChange}"
                            Command="{Binding ChangeLibraryRootCommand}"
                            Padding="12,4"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
