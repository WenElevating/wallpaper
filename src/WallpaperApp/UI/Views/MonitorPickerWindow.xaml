<Window x:Class="WallpaperApp.UI.Views.MonitorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:WallpaperApp.Localization"
        Title="WallpaperApp" Width="560" Height="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc ChooseMonitor}" FontSize="20" FontWeight="Bold"/>

        <ItemsControl x:Name="MonitorList" Grid.Row="1" Margin="0,18,0,0" VerticalAlignment="Top">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Click="Monitor_Click" Tag="{Binding}" Width="180" Height="116" Margin="0,0,14,14"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="6" Margin="14,14,14,8"
                                    Background="{StaticResource CardSurfaceBrush}">
                                <TextBlock Text="{Binding DeviceName}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Center" Opacity="0.7">
                                <Run Text="{Binding Width}"/><Run Text=" × "/><Run Text="{Binding Height}"/>
                            </TextBlock>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="2" Style="{StaticResource PrimaryButtonStyle}"
                Content="{loc:Loc SetOnAllMonitors}" Click="All_Click"
                HorizontalAlignment="Right" Margin="0,8,0,0"/>
    </Grid>
</Window>
