<UserControl x:Class="WallpaperApp.UI.Views.PlaylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:WallpaperApp.Localization"
             Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="28,24">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right" Content="{loc:Loc PlaylistCreateButton}"
                    Command="{Binding CreatePlaylistCommand}" Padding="14,6"/>
            <TextBlock Text="{loc:Loc PlaylistLabel}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>
        <Border Background="{StaticResource CardSurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16">
            <TextBlock Text="{loc:Loc PlaylistEmptyHint}"
                       Foreground="{StaticResource MutedTextBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </DockPanel>
</UserControl>
