<UserControl x:Class="WallpaperApp.UI.Views.PlaylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:WallpaperApp.Localization"
             Foreground="{StaticResource TextBrush}">
    <UserControl.Resources>
        <Style x:Key="PlaylistListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceSelectedBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlainListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorInput" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right"
                    Content="{loc:Loc PlaylistCreateButton}"
                    Command="{Binding CreatePlaylistCommand}"
                    Padding="14,7"/>
            <StackPanel>
                <TextBlock Text="播放列表" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="管理轮播顺序、间隔和显示器绑定"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <ListBox ItemsSource="{Binding Playlists}"
                             SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource PlaylistListItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Members.Count, Mode=OneWay, StringFormat={}{0} items}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                            <TextBlock Text=" / " Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                            <TextBlock Text="{Binding IntervalMinutes, StringFormat={}{0} min}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text=">"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="{loc:Loc PlaylistEmptyHint}"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Playlists.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedPlaylist}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource CardSurfaceBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="间隔" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="随机" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="显示器" Style="{StaticResource PanelTitle}"/>

                        <TextBox Grid.Row="1" Grid.Column="0"
                                 Style="{StaticResource EditorInput}"
                                 Text="{Binding PlaylistName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Style="{StaticResource EditorInput}"
                                 Text="{Binding PlaylistIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Grid.Row="1" Grid.Column="4"
                                  Content="打乱"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="{Binding PlaylistShuffle}"
                                  VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1" Grid.Column="6"
                                  ItemsSource="{Binding Monitors}"
                                  SelectedValue="{Binding SelectedPlaylistMonitorKey, Mode=TwoWay}"
                                  SelectedValuePath="MonitorKey"
                                  DisplayMemberPath="DeviceName"
                                  MinWidth="160"/>
                        <Button Grid.Row="1" Grid.Column="7"
                                Content="绑定"
                                Command="{Binding AssignPlaylistMonitorCommand}"
                                Padding="14,7"
                                Margin="12,0,0,0"/>
                        <Button Grid.Row="1" Grid.Column="8"
                                Content="保存"
                                Command="{Binding SavePlaylistSettingsCommand}"
                                Padding="14,7"
                                Margin="8,0,0,0"/>
                        <Button Grid.Row="1" Grid.Column="9"
                                Content="删除"
                                Command="{Binding DeletePlaylistCommand}"
                                Background="#3F2731"
                                Padding="14,7"
                                Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource CardSurfaceBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding PlaylistMembers.Count, StringFormat={}{0} items}"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="列表内容" Style="{StaticResource PanelTitle}"/>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <ListBox x:Name="MemberList"
                                         ItemsSource="{Binding PlaylistMembers}"
                                         ItemContainerStyle="{StaticResource PlainListItem}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         AllowDrop="True"
                                         PreviewMouseLeftButtonDown="MemberList_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="MemberList_PreviewMouseMove"
                                         Drop="MemberList_Drop"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="::"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding WallpaperName}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="↑"
                                                                Command="{Binding DataContext.MovePlaylistMemberUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="8,3"
                                                                Margin="0,0,6,0"/>
                                                        <Button Content="↓"
                                                                Command="{Binding DataContext.MovePlaylistMemberDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="8,3"
                                                                Margin="0,0,6,0"/>
                                                        <Button Content="移除"
                                                                Command="{Binding DataContext.RemoveFromPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="10,3"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="这个播放列表还没有壁纸。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlaylistMembers.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource CardSurfaceBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="添加壁纸" Style="{StaticResource PanelTitle}"/>

                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{Binding AddableWallpapers}"
                                         ItemContainerStyle="{StaticResource PlainListItem}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="10">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            Content="加入"
                                                            Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="10,3"/>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="已导入的壁纸都在这个播放列表里了。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AddableWallpapers.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedPlaylist}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="选择或新建一个播放列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="然后添加壁纸、调整顺序并绑定到显示器。"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
