<UserControl x:Class="WallpaperApp.UI.Views.WallpaperDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:WallpaperApp.Localization"
             xmlns:vm="clr-namespace:WallpaperApp.UI.ViewModels"
             xmlns:controls="clr-namespace:WallpaperApp.UI.Controls"
             xmlns:this="clr-namespace:WallpaperApp.UI"
             Foreground="{StaticResource TextBrush}">
    <UserControl.Resources>
        <this:DurationMsToTextConverter x:Key="DurConv"/>
        <this:BytesToTextConverter x:Key="SizeConv"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Live preview -->
        <Border Grid.Column="0" CornerRadius="16" ClipToBounds="True" Background="Black"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                Effect="{StaticResource CardShadowEffect}" Margin="0,0,24,0">
            <controls:VideoFrameView x:Name="Player" Stretch="Uniform"/>
        </Border>

        <!-- Info panel -->
        <DockPanel Grid.Column="1" Margin="0,4,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Top" Content="{loc:Loc Back}" Command="{Binding GoBackCommand}"
                    HorizontalAlignment="Left" Margin="0,0,0,16" Padding="14,6"/>

            <TextBlock DockPanel.Dock="Top" Text="{Binding ActiveWallpaper.DisplayName}"
                       FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,22"/>

            <StackPanel DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="{loc:Loc ResolutionLabel}" Width="96" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock>
                        <Run Text="{Binding ActiveWallpaper.Width}"/><Run Text=" × "/><Run Text="{Binding ActiveWallpaper.Height}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="{loc:Loc DurationLabel}" Width="96" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding ActiveWallpaper.DurationMs, Converter={StaticResource DurConv}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="{loc:Loc FormatLabel}" Width="96" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding ActiveWallpaper.ContainerFormat}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="{loc:Loc SizeLabel}" Width="96" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding ActiveWallpaper.FileBytes, Converter={StaticResource SizeConv}}"/>
                </StackPanel>
            </StackPanel>

            <Button DockPanel.Dock="Bottom" Style="{StaticResource PrimaryButtonStyle}"
                    Content="{loc:Loc SetAsWallpaper}" Command="{Binding SetAsWallpaperCommand}"
                    HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
        </DockPanel>
    </Grid>
</UserControl>
